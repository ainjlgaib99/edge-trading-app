# EDGE Trading App — Environment Variables
# Copy this to .env and fill in your values.
# For a static site, put your real values in js/config.js
# The anon key is safe to commit — it's public by design.
# NEVER expose the service_role key.

SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=eyJ...your-anon-key-here
